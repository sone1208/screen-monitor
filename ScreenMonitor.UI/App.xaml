<Application x:Class="ScreenMonitor.UI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>

            <!-- ==================== 颜色（优化对比度） ==================== -->
            <!-- 页面背景：深灰蓝，不过暗 -->
            <SolidColorBrush x:Key="BgPage" Color="#1B1B2F"/>
            <!-- 卡片背景：比页面亮一级 -->
            <SolidColorBrush x:Key="BgCard" Color="#252540"/>
            <!-- 输入框背景 -->
            <SolidColorBrush x:Key="BgInput" Color="#1A1A30"/>
            <!-- 边框 -->
            <SolidColorBrush x:Key="BorderColor" Color="#2F2F50"/>
            <SolidColorBrush x:Key="BorderLight" Color="#3A3A5C"/>

            <!-- 文字（提高亮度确保清晰） -->
            <SolidColorBrush x:Key="TextPrimary" Color="#F0F0FF"/>
            <SolidColorBrush x:Key="TextSecondary" Color="#A0A0C0"/>
            <SolidColorBrush x:Key="TextMuted" Color="#707090"/>

            <!-- 强调色 -->
            <SolidColorBrush x:Key="AccentPrimary" Color="#6366F1"/>
            <SolidColorBrush x:Key="AccentGreen" Color="#22C55E"/>
            <SolidColorBrush x:Key="AccentRed" Color="#EF4444"/>
            <SolidColorBrush x:Key="AccentOrange" Color="#F59E0B"/>
            <SolidColorBrush x:Key="AccentBlue" Color="#3B82F6"/>

            <!-- 渐变 -->
            <LinearGradientBrush x:Key="GradPrimary" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#6366F1" Offset="0"/>
                <GradientStop Color="#818CF8" Offset="1"/>
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="GradGreen" StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#22C55E" Offset="0"/>
                <GradientStop Color="#16A34A" Offset="1"/>
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="GradOrange" StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#F59E0B" Offset="0"/>
                <GradientStop Color="#D97706" Offset="1"/>
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="GradRed" StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#EF4444" Offset="0"/>
                <GradientStop Color="#DC2626" Offset="1"/>
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="GradBlue" StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#3B82F6" Offset="0"/>
                <GradientStop Color="#6366F1" Offset="1"/>
            </LinearGradientBrush>

            <!-- ==================== 文字按钮（设置/返回用） ==================== -->
            <Style x:Key="TextBtn" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="10,5"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Foreground" Value="#818CF8"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Foreground" Value="#A5B4FC"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- ==================== 主要按钮 ==================== -->
            <Style x:Key="PrimaryBtn" TargetType="Button">
                <Setter Property="Background" Value="#6366F1"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="14,7"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" 
                                    CornerRadius="6" BorderThickness="0" SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#818CF8"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- ==================== 次要按钮 ==================== -->
            <Style x:Key="SecondaryBtn" TargetType="Button">
                <Setter Property="Background" Value="#252540"/>
                <Setter Property="Foreground" Value="#C0C0D8"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="14,7"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                    BorderBrush="#3A3A5C" BorderThickness="{TemplateBinding BorderThickness}"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#2F2F50"/>
                        <Setter Property="Foreground" Value="#F0F0FF"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- ==================== 输入框 ==================== -->
            <Style x:Key="ModernInput" TargetType="TextBox">
                <Setter Property="Background" Value="#1A1A30"/>
                <Setter Property="Foreground" Value="#F0F0FF"/>
                <Setter Property="BorderBrush" Value="#3A3A5C"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Height" Value="32"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="Padding" Value="8,0"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="CaretBrush" Value="#818CF8"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TextBox">
                            <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ==================== 卡片 ==================== -->
            <Style x:Key="Card" TargetType="Border">
                <Setter Property="Background" Value="#252540"/>
                <Setter Property="CornerRadius" Value="10"/>
                <Setter Property="BorderBrush" Value="#2F2F50"/>
                <Setter Property="BorderThickness" Value="1"/>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>

