<Application x:Class="ScreenMonitor.UI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>

            <!-- ==================== Color Palette ==================== -->
            <SolidColorBrush x:Key="BgCanvas" Color="#0C0C1A"/>         <!-- 深空画布 -->
            <SolidColorBrush x:Key="BgSurface" Color="#141428"/>        <!-- 表面层 -->
            <SolidColorBrush x:Key="BgCard" Color="#1A1A32"/>           <!-- 卡片 -->
            <SolidColorBrush x:Key="BgCardHover" Color="#222240"/>      <!-- 卡片悬停 -->
            <SolidColorBrush x:Key="BgInput" Color="#121226"/>          <!-- 输入框 -->

            <SolidColorBrush x:Key="BorderSoft" Color="#2A2A4A"/>       <!-- 柔和边框 -->
            <SolidColorBrush x:Key="BorderSubtle" Color="#1E1E3A"/>     <!-- 更淡边框 -->

            <SolidColorBrush x:Key="TextPrimary" Color="#E8E8F2"/>      <!-- 主文字 -->
            <SolidColorBrush x:Key="TextSecondary" Color="#9494B8"/>    <!-- 次要文字 -->
            <SolidColorBrush x:Key="TextMuted" Color="#606080"/>        <!-- 辅助文字 -->

            <SolidColorBrush x:Key="AccentPrimary" Color="#7C6FF0"/>    <!-- 紫蓝主色 -->
            <SolidColorBrush x:Key="AccentPurple" Color="#A78BFA"/>     <!-- 浅紫 -->
            <SolidColorBrush x:Key="AccentGreen" Color="#00D9A6"/>      <!-- 青绿活跃 -->
            <SolidColorBrush x:Key="AccentAmber" Color="#FFA640"/>      <!-- 琥珀闲置 -->
            <SolidColorBrush x:Key="AccentRed" Color="#FF5C6C"/>        <!-- 红色 -->

            <SolidColorBrush x:Key="PulseDot" Color="#00D9A6"/>         <!-- 脉冲点 -->

            <!-- Gradient Brushes -->
            <LinearGradientBrush x:Key="GradPrimary" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#7C6FF0" Offset="0"/>
                <GradientStop Color="#A78BFA" Offset="1"/>
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="GradGreen" StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#00D9A6" Offset="0"/>
                <GradientStop Color="#00B894" Offset="1"/>
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="GradAmber" StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#FFA640" Offset="0"/>
                <GradientStop Color="#E8922E" Offset="1"/>
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="GradRed" StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#FF5C6C" Offset="0"/>
                <GradientStop Color="#E84A5A" Offset="1"/>
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="GradBlue" StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#6366F1" Offset="0"/>
                <GradientStop Color="#7C6FF0" Offset="1"/>
            </LinearGradientBrush>

            <!-- ==================== Styles ==================== -->

            <!-- 文字按钮 -->
            <Style x:Key="TextBtn" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="10,5"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Foreground" Value="#7C6FF0"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Foreground" Value="#A78BFA"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- 主要按钮 -->
            <Style x:Key="PrimaryBtn" TargetType="Button">
                <Setter Property="Background" Value="#7C6FF0"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="16,8"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="8" BorderThickness="0" SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#A78BFA"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- 次要按钮 -->
            <Style x:Key="SecondaryBtn" TargetType="Button">
                <Setter Property="Background" Value="#1E1E3A"/>
                <Setter Property="Foreground" Value="#C0C0D8"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="14,7"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="8"
                                    BorderBrush="#2A2A4A" BorderThickness="{TemplateBinding BorderThickness}"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#2A2A4A"/>
                        <Setter Property="Foreground" Value="#E8E8F2"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- 输入框 -->
            <Style x:Key="ModernInput" TargetType="TextBox">
                <Setter Property="Background" Value="#121226"/>
                <Setter Property="Foreground" Value="#E8E8F2"/>
                <Setter Property="BorderBrush" Value="#2A2A4A"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Height" Value="34"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="Padding" Value="10,0"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="CaretBrush" Value="#7C6FF0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TextBox">
                            <Border Background="{TemplateBinding Background}" CornerRadius="8"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- 卡片容器 -->
            <Style x:Key="Card" TargetType="Border">
                <Setter Property="Background" Value="#1A1A32"/>
                <Setter Property="CornerRadius" Value="12"/>
                <Setter Property="BorderBrush" Value="#1E1E3A"/>
                <Setter Property="BorderThickness" Value="1"/>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
