<Application x:Class="ScreenMonitor.UI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <!-- 全局颜色 -->
            <SolidColorBrush x:Key="BgPage" Color="#131428"/>
            <SolidColorBrush x:Key="BgSidebar" Color="#0E0F22"/>
            <SolidColorBrush x:Key="BgCard" Color="#1C1E3A"/>
            <SolidColorBrush x:Key="TextPrimary" Color="#E8E8F0"/>
            <SolidColorBrush x:Key="TextSecondary" Color="#7A7C94"/>
            <SolidColorBrush x:Key="TextMuted" Color="#505270"/>
            <SolidColorBrush x:Key="AccentBlue" Color="#4A8EFF"/>
            <SolidColorBrush x:Key="AccentGreen" Color="#52C41A"/>
            <SolidColorBrush x:Key="AccentRed" Color="#FF4D4F"/>
            <SolidColorBrush x:Key="AccentOrange" Color="#FAAD14"/>
            <SolidColorBrush x:Key="AccentPurple" Color="#B37FEB"/>
            <SolidColorBrush x:Key="BorderColor" Color="#2A2C4A"/>

            <Style TargetType="Button" x:Key="NavButton">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="12,8"/>
                <Setter Property="Margin" Value="0,2"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Foreground" Value="#B8B8D0"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
