<Window x:Class="ScreenMonitor.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="屏幕监控" Height="650" Width="950"
        WindowStartupLocation="CenterScreen"
        Background="#131428">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Background="#0E0F22" Grid.Column="0">
            <StackPanel Margin="10">
                <TextBlock Text="屏幕监控" FontSize="18" FontWeight="Bold"
                           Foreground="#E8E8F0" Margin="10,15"/>
                <TextBlock Text="应用使用统计" FontSize="11"
                           Foreground="#7A7C94" Margin="10,0,10,20"/>

                <Button Content=" 概览" Style="{StaticResource NavButton}"
                        Foreground="#B8B8D0" Click="Dashboard_Click"/>
                <Button Content=" 报表" Style="{StaticResource NavButton}"
                        Foreground="#B8B8D0" Click="Reports_Click"/>
                <Button Content=" 设置" Style="{StaticResource NavButton}"
                        Foreground="#B8B8D0" Click="Settings_Click"/>
            </StackPanel>
        </Border>

        <!-- Content Area -->
        <Frame x:Name="ContentFrame" Grid.Column="1"
               NavigationUIVisibility="Hidden" Margin="20"/>
    </Grid>
</Window>
