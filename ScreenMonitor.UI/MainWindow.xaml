<Window x:Class="ScreenMonitor.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Screen Monitor" Height="650" Width="950"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Background="#2C3E50" Grid.Column="0">
            <StackPanel Margin="10">
                <TextBlock Text="Screen Monitor" FontSize="18" FontWeight="Bold"
                           Foreground="White" Margin="10,15"/>
                <TextBlock Text="App Usage Tracker" FontSize="11"
                           Foreground="#95A5A6" Margin="10,0,10,20"/>

                <Button Content=" Dashboard" Style="{StaticResource NavButton}"
                        Foreground="White" Click="Dashboard_Click"/>
                <Button Content=" Reports" Style="{StaticResource NavButton}"
                        Foreground="White" Click="Reports_Click"/>
                <Button Content=" Timeline" Style="{StaticResource NavButton}"
                        Foreground="White" Click="Timeline_Click"/>
                <Button Content=" Settings" Style="{StaticResource NavButton}"
                        Foreground="White" Click="Settings_Click"/>
            </StackPanel>
        </Border>

        <!-- Content Area -->
        <Frame x:Name="ContentFrame" Grid.Column="1"
               NavigationUIVisibility="Hidden" Margin="20"/>
    </Grid>
</Window>