<Page x:Class="ScreenMonitor.UI.Views.AppDetailView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="应用详情" Background="#1B1B2F">
    <ScrollViewer>
        <StackPanel Margin="28,20,28,30">

            <Button Content="← 返回概览" Click="Back_Click"
                    Style="{StaticResource TextBtn}" HorizontalAlignment="Left" Margin="0,0,0,16"/>

            <Border Style="{StaticResource Card}" Padding="20" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock x:Name="AppNameText" FontSize="22" FontWeight="Bold"
                               Foreground="#F0F0FF" Margin="0,0,0,4"/>
                    <TextBlock x:Name="TotalTimeText" FontSize="13" Foreground="#A0A0C0"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Padding="20">
                <StackPanel>
                    <TextBlock Text="过去 24 小时使用分布" FontSize="15" FontWeight="Bold"
                               Foreground="#F0F0FF" Margin="0,0,0,16"/>
                    <Border Background="#151528" CornerRadius="6" Padding="12,10,12,8">
                        <Grid Height="280">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="24"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Y轴标注区 -->
                            <Grid Grid.Column="0" Grid.Row="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                            </Grid>

                            <!-- 柱状图区域 -->
                            <Grid x:Name="ChartGrid" Grid.Column="1" Grid.Row="0"
                                  VerticalAlignment="Stretch" Margin="0,0,0,0"/>

                            <!-- X轴标签 -->
                            <WrapPanel x:Name="XAxisPanel" Grid.Column="1" Grid.Row="1"
                                       Margin="0,6,0,0"/>
                        </Grid>
                    </Border>
                    <TextBlock x:Name="NoDataText" Text="暂无该应用的使用数据"
                               Foreground="#707090" FontSize="13" Visibility="Collapsed"
                               Margin="0,20,0,0" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
