<Page x:Class="ScreenMonitor.UI.Views.AppDetailView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="应用详情" Background="#0C0C1A">
    <ScrollViewer>
        <StackPanel Margin="32,24,32,32">

            <Button Content="← 返回概览" Click="Back_Click"
                    Style="{StaticResource TextBtn}" HorizontalAlignment="Left" Margin="0,0,0,20"/>

            <Border Style="{StaticResource Card}" Padding="24,20" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock x:Name="AppNameText" FontSize="22" FontWeight="SemiBold"
                               Foreground="#E8E8F2" Margin="0,0,0,6"/>
                    <TextBlock x:Name="TotalTimeText" FontSize="13" Foreground="#9494B8"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Padding="24,20">
                <StackPanel>
                    <TextBlock Text="过去 24 小时使用分布" FontSize="15" FontWeight="SemiBold"
                               Foreground="#E8E8F2" Margin="0,0,0,16"/>
                    <Border Background="#121226" CornerRadius="8" Padding="12,10,12,8">
                        <Grid Height="280">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="24"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid x:Name="ChartGrid" Grid.Column="1" Grid.Row="0"
                                  VerticalAlignment="Stretch" Margin="0,0,0,0"/>
                            <WrapPanel x:Name="XAxisPanel" Grid.Column="1" Grid.Row="1"
                                       Margin="0,6,0,0"/>
                        </Grid>
                    </Border>
                    <TextBlock x:Name="NoDataText" Text="暂无该应用的使用数据"
                               Foreground="#606080" FontSize="13" Visibility="Collapsed"
                               Margin="0,24,0,0" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
