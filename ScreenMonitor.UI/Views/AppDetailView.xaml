<Page x:Class="ScreenMonitor.UI.Views.AppDetailView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="应用详情" Background="#1B1B2F">
    <ScrollViewer>
        <StackPanel Margin="28,20,28,30">
            <Button Content="← 返回概览" Click="Back_Click" 
                    Style="{StaticResource TextBtn}" HorizontalAlignment="Left" Margin="0,0,0,16"/>

            <Border Style="{StaticResource Card}" Padding="20" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock x:Name="AppNameText" FontSize="22" FontWeight="Bold"
                               Foreground="#F0F0FF" Margin="0,0,0,4"/>
                    <TextBlock x:Name="TotalTimeText" FontSize="13" Foreground="#A0A0C0"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Padding="20">
                <StackPanel>
                    <TextBlock Text="过去 24 小时使用分布" FontSize="15" FontWeight="Bold"
                               Foreground="#F0F0FF" Margin="0,0,0,16"/>
                    <Grid Height="300" Margin="0,0,0,8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="20"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="20"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="45"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" VerticalAlignment="Top">
                            <TextBlock Text="60" FontSize="9" Foreground="#707090" HorizontalAlignment="Right" Margin="0,0,6,0"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="30" FontSize="9" Foreground="#707090" HorizontalAlignment="Right" Margin="0,0,6,0"/>
                        </StackPanel>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="0" FontSize="9" Foreground="#707090" HorizontalAlignment="Right" Margin="0,0,6,0"/>

                        <Grid x:Name="ChartGrid" Grid.Row="1" Grid.Column="1" VerticalAlignment="Stretch"/>
                        <WrapPanel x:Name="XAxisPanel" Grid.Row="2" Grid.Column="1" Margin="0,4,0,0"/>
                    </Grid>
                </StackPanel>
            </Border>

            <TextBlock x:Name="NoDataText" Text="暂无该应用的使用数据"
                       Foreground="#707090" FontSize="13" Visibility="Collapsed"
                       Margin="0,30,0,0" HorizontalAlignment="Center"/>
        </StackPanel>
    </ScrollViewer>
</Page>
