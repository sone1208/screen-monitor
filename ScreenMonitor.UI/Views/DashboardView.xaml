<Page x:Class="ScreenMonitor.UI.Views.DashboardView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Dashboard" Background="Transparent">
    <ScrollViewer>
        <StackPanel Margin="10">
            <TextBlock Text="Today's Overview" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>

            <!-- Summary Cards -->
            <WrapPanel Margin="0,0,0,20">
                <Border Background="White" CornerRadius="8" Padding="20" Margin="0,0,15,0" Width="180" Effect="{StaticResource Shadow}">
                    <StackPanel>
                        <TextBlock Text="Total Time" FontSize="12" Foreground="#888"/>
                        <TextBlock x:Name="TotalTimeText" Text="--" FontSize="28" FontWeight="Bold" Foreground="#2C3E50"/>
                    </StackPanel>
                </Border>
                <Border Background="White" CornerRadius="8" Padding="20" Margin="0,0,15,0" Width="180">
                    <StackPanel>
                        <TextBlock Text="Active Time" FontSize="12" Foreground="#888"/>
                        <TextBlock x:Name="ActiveTimeText" Text="--" FontSize="28" FontWeight="Bold" Foreground="#27AE60"/>
                    </StackPanel>
                </Border>
                <Border Background="White" CornerRadius="8" Padding="20" Margin="0,0,15,0" Width="180">
                    <StackPanel>
                        <TextBlock Text="Idle Time" FontSize="12" Foreground="#888"/>
                        <TextBlock x:Name="IdleTimeText" Text="--" FontSize="28" FontWeight="Bold" Foreground="#E74C3C"/>
                    </StackPanel>
                </Border>
                <Border Background="White" CornerRadius="8" Padding="20" Width="180">
                    <StackPanel>
                        <TextBlock Text="Apps Used" FontSize="12" Foreground="#888"/>
                        <TextBlock x:Name="AppsCountText" Text="--" FontSize="28" FontWeight="Bold" Foreground="#3498DB"/>
                    </StackPanel>
                </Border>
            </WrapPanel>

            <!-- Bar Chart: Top 5 Applications -->
            <Border Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Top Applications Today" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>
                    <StackPanel x:Name="ChartPanel" />
                    <TextBlock x:Name="NoDataText" Text="No data yet. Start using your computer to see stats."
                               Foreground="#999" FontSize="14" Visibility="Collapsed" Margin="0,20,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>