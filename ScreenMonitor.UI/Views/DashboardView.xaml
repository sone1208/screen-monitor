<Page x:Class="ScreenMonitor.UI.Views.DashboardView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="概览" Background="#0C0C1A">
    <ScrollViewer>
        <StackPanel Margin="32,24,32,32">

            <!-- 顶栏 -->
            <Grid Margin="0,0,0,28">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="屏幕监控" FontSize="24" FontWeight="SemiBold"
                               Foreground="#E8E8F2"/>
                    <TextBlock x:Name="TodayDateText" Text="" FontSize="12"
                               Foreground="#606080" Margin="0,4,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Content="⚙" FontSize="18"
                        Click="Settings_Click"
                        Style="{StaticResource TextBtn}" Width="36" Height="36"
                        ToolTip="设置"/>
            </Grid>

            <!-- 统计卡片：4 列 -->
            <UniformGrid Columns="4" Margin="0,0,0,28">
                <Border Style="{StaticResource Card}" Padding="20,18" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="监控时长" FontSize="11" Foreground="#606080"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="TotalTimeText" Text="--" FontSize="26" FontWeight="SemiBold"
                                   Foreground="#E8E8F2" Margin="0,10,0,2"/>
                        <TextBlock Text="至今" FontSize="10" Foreground="#606080"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Padding="20,18" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="活跃" FontSize="11" Foreground="#606080"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="ActiveTimeText" Text="--" FontSize="26" FontWeight="SemiBold"
                                   Foreground="#00D9A6" Margin="0,10,0,2"/>
                        <TextBlock x:Name="ActivePctText" Text="" FontSize="10" Foreground="#00D9A6"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Padding="20,18" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="闲置" FontSize="11" Foreground="#606080"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="IdleTimeText" Text="--" FontSize="26" FontWeight="SemiBold"
                                   Foreground="#FFA640" Margin="0,10,0,2"/>
                        <TextBlock x:Name="IdlePctText" Text="" FontSize="10" Foreground="#FFA640"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Padding="20,18">
                    <StackPanel>
                        <TextBlock Text="应用" FontSize="11" Foreground="#606080"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="AppsCountText" Text="--" FontSize="26" FontWeight="SemiBold"
                                   Foreground="#7C6FF0" Margin="0,10,0,2"/>
                        <TextBlock Text="今日记录" FontSize="10" Foreground="#606080"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- 应用排行 -->
            <Border Style="{StaticResource Card}" Padding="0" Margin="0,0,0,16">
                <StackPanel>
                    <!-- 表头 -->
                    <Grid Margin="24,20,24,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="应用使用排行" FontSize="16" FontWeight="SemiBold"
                                   Foreground="#E8E8F2"/>
                        <WrapPanel Grid.Column="1">
                            <Button x:Name="PrevBtn" Content="◀" Click="PrevPage_Click"
                                    Style="{StaticResource SecondaryBtn}" Padding="6,3" FontSize="10"
                                    Visibility="Collapsed" Margin="0,0,6,0"/>
                            <TextBlock x:Name="PageInfo" VerticalAlignment="Center" FontSize="11"
                                       Foreground="#606080" Margin="0,0,6,0"/>
                            <Button x:Name="NextBtn" Content="▶" Click="NextPage_Click"
                                    Style="{StaticResource SecondaryBtn}" Padding="6,3" FontSize="10"
                                    Visibility="Collapsed"/>
                        </WrapPanel>
                    </Grid>
                    <StackPanel x:Name="ChartPanel" Margin="0,8,0,0"/>
                    <StackPanel x:Name="PaginationPanel" Visibility="Collapsed"
                                HorizontalAlignment="Center" Margin="0,8,0,16"/>
                    <TextBlock x:Name="NoDataText" Text="暂无数据，程序正在采集使用记录..."
                               Foreground="#606080" FontSize="13" Visibility="Collapsed"
                               Margin="0,30,0,40" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
