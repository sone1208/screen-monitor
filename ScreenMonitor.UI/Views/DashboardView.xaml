<Page x:Class="ScreenMonitor.UI.Views.DashboardView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="概览" Background="#131428">
    <ScrollViewer>
        <StackPanel Margin="10">
            <TextBlock Text="今日概览" FontSize="24" FontWeight="Bold" 
                       Foreground="#E8E8F0" Margin="0,0,0,20"/>

            <!-- Summary Cards -->
            <WrapPanel Margin="0,0,0,20">
                <Border Background="#1C1E3A" CornerRadius="10" Padding="15,12" 
                        Margin="0,0,10,10" Width="160" BorderThickness="1" BorderBrush="#2A2C4A">
                    <StackPanel>
                        <TextBlock Text="总时间" FontSize="12" Foreground="#7A7C94"/>
                        <TextBlock x:Name="TotalTimeText" Text="--" FontSize="22" FontWeight="Bold"
                                   Foreground="#E8E8F0" TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                    </StackPanel>
                </Border>
                <Border Background="#1C1E3A" CornerRadius="10" Padding="15,12"
                        Margin="0,0,10,10" Width="160" BorderThickness="1" BorderBrush="#2A2C4A">
                    <StackPanel>
                        <TextBlock Text="活跃时间" FontSize="12" Foreground="#7A7C94"/>
                        <TextBlock x:Name="ActiveTimeText" Text="--" FontSize="22" FontWeight="Bold"
                                   Foreground="#52C41A" TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                    </StackPanel>
                </Border>
                <Border Background="#1C1E3A" CornerRadius="10" Padding="15,12"
                        Margin="0,0,10,10" Width="160" BorderThickness="1" BorderBrush="#2A2C4A">
                    <StackPanel>
                        <TextBlock Text="闲置时间" FontSize="12" Foreground="#7A7C94"/>
                        <TextBlock x:Name="IdleTimeText" Text="--" FontSize="22" FontWeight="Bold"
                                   Foreground="#FF4D4F" TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                    </StackPanel>
                </Border>
                <Border Background="#1C1E3A" CornerRadius="10" Padding="15,12"
                        Margin="0,0,0,10" Width="160" BorderThickness="1" BorderBrush="#2A2C4A">
                    <StackPanel>
                        <TextBlock Text="应用数" FontSize="12" Foreground="#7A7C94"/>
                        <TextBlock x:Name="AppsCountText" Text="--" FontSize="22" FontWeight="Bold"
                                   Foreground="#4A8EFF" TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                    </StackPanel>
                </Border>
            </WrapPanel>

            <!-- App List -->
            <Border Background="#1C1E3A" CornerRadius="10" Padding="20"
                    Margin="0,0,0,20" BorderThickness="1" BorderBrush="#2A2C4A">
                <StackPanel>
                    <TextBlock Text="今日应用排行" FontSize="16" FontWeight="Bold"
                               Foreground="#E8E8F0" Margin="0,0,0,15"/>
                    <StackPanel x:Name="ChartPanel" />
                    <TextBlock x:Name="NoDataText" Text="暂无数据，开始使用电脑后将自动记录"
                               Foreground="#505270" FontSize="14" Visibility="Collapsed"
                               Margin="0,20,0,0"/>

                    <!-- 分页 -->
                    <StackPanel x:Name="PaginationPanel" Orientation="Horizontal"
                                HorizontalAlignment="Center" Margin="0,10,0,0">
                        <Button x:Name="PrevBtn" Content="← 上一页" Click="PrevPage_Click"
                                Background="#2A2C4A" Foreground="#B8B8D0"
                                BorderThickness="1" BorderBrush="#3A3C5A"
                                Padding="8,4" Margin="0,0,10,0" FontSize="12"
                                Visibility="Collapsed" Cursor="Hand"/>
                        <TextBlock x:Name="PageInfo" Text="1 / 1" VerticalAlignment="Center"
                                   FontSize="12" Foreground="#7A7C94" Visibility="Collapsed"/>
                        <Button x:Name="NextBtn" Content="下一页 →" Click="NextPage_Click"
                                Background="#2A2C4A" Foreground="#B8B8D0"
                                BorderThickness="1" BorderBrush="#3A3C5A"
                                Padding="8,4" Margin="10,0,0,0" FontSize="12"
                                Visibility="Collapsed" Cursor="Hand"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
