<Page x:Class="ScreenMonitor.UI.Views.DashboardView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="概览" Background="#0B0B1A">
    <ScrollViewer>
        <StackPanel Margin="24,20,24,30">

            <!-- 页面标题 -->
            <TextBlock FontSize="26" FontWeight="Bold" Margin="0,0,0,6">
                <Run Text="今日概览" Foreground="#E8E8F8"/>
            </TextBlock>
            <TextBlock x:Name="TodayDateText" Text="" FontSize="12" 
                       Foreground="#3D3D5C" Margin="0,0,0,24"/>

            <!-- 统计卡片 2x2 网格 -->
            <UniformGrid Columns="4" Rows="1" Margin="0,0,0,24">
                <!-- 总时间 -->
                <Border Style="{StaticResource Card}" Padding="18,16" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="总使用" FontSize="11" Foreground="#6B6B8D"/>
                        <TextBlock x:Name="TotalTimeText" Text="--" FontSize="26" FontWeight="Bold"
                                   Foreground="#E8E8F8" TextTrimming="CharacterEllipsis" Margin="0,6,0,0"
                                   ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                        <TextBlock Text="含活跃 + 闲置" FontSize="10" Foreground="#3D3D5C" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- 活跃时间 -->
                <Border Style="{StaticResource Card}" Padding="18,16" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="活跃时间" FontSize="11" Foreground="#6B6B8D"/>
                        <TextBlock x:Name="ActiveTimeText" Text="--" FontSize="26" FontWeight="Bold"
                                   Foreground="#22C55E" TextTrimming="CharacterEllipsis" Margin="0,6,0,0"
                                   ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                        <TextBlock x:Name="ActivePctText" Text="" FontSize="10" Foreground="#3D3D5C" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- 闲置时间 -->
                <Border Style="{StaticResource Card}" Padding="18,16" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="闲置时间" FontSize="11" Foreground="#6B6B8D"/>
                        <TextBlock x:Name="IdleTimeText" Text="--" FontSize="26" FontWeight="Bold"
                                   Foreground="#F59E0B" TextTrimming="CharacterEllipsis" Margin="0,6,0,0"
                                   ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                        <TextBlock x:Name="IdlePctText" Text="" FontSize="10" Foreground="#3D3D5C" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- 应用数 -->
                <Border Style="{StaticResource Card}" Padding="18,16">
                    <StackPanel>
                        <TextBlock Text="监控应用" FontSize="11" Foreground="#6B6B8D"/>
                        <TextBlock x:Name="AppsCountText" Text="--" FontSize="26" FontWeight="Bold"
                                   Foreground="#818CF8" Margin="0,6,0,0"/>
                        <TextBlock Text="今日已记录" FontSize="10" Foreground="#3D3D5C" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- 应用排行 -->
            <Border Style="{StaticResource Card}" Padding="0" Margin="0,0,0,20">
                <StackPanel>
                    <!-- 标题区 -->
                    <Grid Margin="20,18,20,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="今日应用排行" FontSize="16" FontWeight="Bold"
                                   Foreground="#E8E8F8"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" 
                                    x:Name="PaginationPanel" Visibility="Collapsed">
                            <Button x:Name="PrevBtn" Content="←" Click="PrevPage_Click"
                                    Style="{StaticResource SecondaryBtn}" Padding="6,2" FontSize="11"
                                    Margin="0,0,6,0" Visibility="Collapsed"/>
                            <TextBlock x:Name="PageInfo" Text="" VerticalAlignment="Center"
                                       FontSize="11" Foreground="#6B6B8D" Margin="0,0,6,0"/>
                            <Button x:Name="NextBtn" Content="→" Click="NextPage_Click"
                                    Style="{StaticResource SecondaryBtn}" Padding="6,2" FontSize="11"
                                    Visibility="Collapsed"/>
                        </StackPanel>
                    </Grid>

                    <!-- 分隔线 -->
                    <Border Height="1" Background="#1E1E38" Margin="0"/>

                    <!-- 排行列表 -->
                    <StackPanel x:Name="ChartPanel" Margin="0,4,0,4"/>

                    <!-- 空状态 -->
                    <TextBlock x:Name="NoDataText" Text="暂无数据，开始使用电脑后将自动记录"
                               Foreground="#3D3D5C" FontSize="13" Visibility="Collapsed"
                               Margin="0,20,0,20" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
