<Page x:Class="ScreenMonitor.UI.Views.DashboardView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="概览" Background="#1B1B2F">
    <ScrollViewer>
        <StackPanel Margin="28,20,28,30">

            <!-- 顶部标题栏 + 设置按钮 -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="屏幕监控" FontSize="24" FontWeight="Bold" Foreground="#F0F0FF"/>
                    <TextBlock x:Name="TodayDateText" Text="" FontSize="12" Foreground="#707090" Margin="0,4,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Content="⚙ 设置" Click="Settings_Click"
                        Style="{StaticResource TextBtn}" VerticalAlignment="Center"/>
            </Grid>

            <!-- 统计卡片：4 列等宽，不用省略号 -->
            <UniformGrid Columns="4" Margin="0,0,0,24">
                <Border Style="{StaticResource Card}" Padding="18,16" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="总时间" FontSize="11" Foreground="#A0A0C0"/>
                        <TextBlock x:Name="TotalTimeText" Text="--" FontSize="22" FontWeight="Bold"
                                   Foreground="#F0F0FF" Margin="0,8,0,0"/>
                        <TextBlock Text="含活跃与闲置" FontSize="10" Foreground="#707090" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Padding="18,16" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="活跃时间" FontSize="11" Foreground="#A0A0C0"/>
                        <TextBlock x:Name="ActiveTimeText" Text="--" FontSize="22" FontWeight="Bold"
                                   Foreground="#22C55E" Margin="0,8,0,0"/>
                        <TextBlock x:Name="ActivePctText" Text="" FontSize="10" Foreground="#707090" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Padding="18,16" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="闲置时间" FontSize="11" Foreground="#A0A0C0"/>
                        <TextBlock x:Name="IdleTimeText" Text="--" FontSize="22" FontWeight="Bold"
                                   Foreground="#F59E0B" Margin="0,8,0,0"/>
                        <TextBlock x:Name="IdlePctText" Text="" FontSize="10" Foreground="#707090" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Padding="18,16">
                    <StackPanel>
                        <TextBlock Text="应用数" FontSize="11" Foreground="#A0A0C0"/>
                        <TextBlock x:Name="AppsCountText" Text="--" FontSize="22" FontWeight="Bold"
                                   Foreground="#818CF8" Margin="0,8,0,0"/>
                        <TextBlock Text="今日已记录" FontSize="10" Foreground="#707090" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- 应用排行 -->
            <Border Style="{StaticResource Card}" Padding="0">
                <StackPanel>
                    <!-- 标题 + 分页 -->
                    <Grid Margin="20,16,20,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="应用排行" FontSize="15" FontWeight="Bold"
                                   Foreground="#F0F0FF"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" 
                                    x:Name="PaginationPanel" Visibility="Collapsed">
                            <Button x:Name="PrevBtn" Content="←" Click="PrevPage_Click"
                                    Style="{StaticResource SecondaryBtn}" Padding="6,2" FontSize="11"
                                    Margin="0,0,8,0" Visibility="Collapsed"/>
                            <TextBlock x:Name="PageInfo" Text="" VerticalAlignment="Center"
                                       FontSize="12" Foreground="#A0A0C0" Margin="0,0,8,0"/>
                            <Button x:Name="NextBtn" Content="→" Click="NextPage_Click"
                                    Style="{StaticResource SecondaryBtn}" Padding="6,2" FontSize="11"
                                    Visibility="Collapsed"/>
                        </StackPanel>
                    </Grid>

                    <Border Height="1" Background="#2F2F50" Margin="0"/>

                    <StackPanel x:Name="ChartPanel" Margin="0,4,0,4"/>

                    <TextBlock x:Name="NoDataText" Text="暂无数据，开始使用电脑后将自动记录"
                               Foreground="#707090" FontSize="13" Visibility="Collapsed"
                               Margin="0,24,0,24" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
