<Page x:Class="ScreenMonitor.UI.Views.ReportView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="报表" Background="#0B0B1A">
    <ScrollViewer>
        <StackPanel Margin="24,20,24,30">
            <TextBlock FontSize="26" FontWeight="Bold" Margin="0,0,0,20">
                <Run Text="使用报表" Foreground="#E8E8F8"/>
            </TextBlock>

            <!-- 工具栏 -->
            <Border Style="{StaticResource Card}" Padding="16" Margin="0,0,0,16">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="📅" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <DatePicker x:Name="ReportDatePicker" SelectedDateChanged="OnDateChanged" 
                                Background="#0E0E20" Foreground="#E8E8F8"
                                BorderBrush="#2A2A4A" Margin="0,0,16,0"/>
                    <Button Content="导出 CSV" Click="ExportCsv_Click" 
                            Style="{StaticResource SecondaryBtn}" Margin="0,0,8,0"/>
                    <Button Content="导出 JSON" Click="ExportJson_Click" 
                            Style="{StaticResource SecondaryBtn}"/>
                </StackPanel>
            </Border>

            <!-- 统计卡片 -->
            <UniformGrid Columns="4" Rows="1" Margin="0,0,0,16">
                <Border Style="{StaticResource Card}" Padding="16" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="活跃总时长" FontSize="11" Foreground="#6B6B8D"/>
                        <TextBlock x:Name="RptActiveText" Text="--" FontSize="22" FontWeight="Bold"
                                   Foreground="#22C55E" TextTrimming="CharacterEllipsis" Margin="0,6,0,0"
                                   ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Padding="16" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="会话数" FontSize="11" Foreground="#6B6B8D"/>
                        <TextBlock x:Name="RptSessionsText" Text="--" FontSize="22" FontWeight="Bold"
                                   Foreground="#818CF8" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
                <!-- 占位对齐 -->
                <Border Background="Transparent"/>
                <Border Background="Transparent"/>
            </UniformGrid>

            <!-- 会话列表 -->
            <Border Style="{StaticResource Card}" Padding="0" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="会话详情" FontSize="15" FontWeight="Bold"
                               Foreground="#E8E8F8" Margin="20,16,20,12"/>
                    <Border Height="1" Background="#1E1E38"/>
                    <ListView x:Name="SessionList" Height="350" 
                              Background="Transparent" Foreground="#E8E8F8"
                              BorderThickness="0" Margin="8,4">
                        <ListView.Resources>
                            <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#141428"/>
                        </ListView.Resources>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="应用" Width="120" DisplayMemberBinding="{Binding ProcessName}"/>
                                <GridViewColumn Header="窗口" Width="200" DisplayMemberBinding="{Binding WindowTitle}"/>
                                <GridViewColumn Header="开始时间" Width="130" DisplayMemberBinding="{Binding StartTime}"/>
                                <GridViewColumn Header="时长" Width="80" DisplayMemberBinding="{Binding DurationText}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
