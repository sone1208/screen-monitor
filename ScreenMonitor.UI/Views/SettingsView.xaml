<Page x:Class="ScreenMonitor.UI.Views.SettingsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Settings" Background="Transparent">
    <ScrollViewer>
        <StackPanel Margin="10">
            <TextBlock Text="Settings" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>

            <!-- Ignore List -->
            <Border Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="Ignored Applications" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                    <TextBlock Text="Processes added here will not be tracked." Foreground="#888" FontSize="12" Margin="0,0,0,10"/>
                    <WrapPanel Margin="0,0,0,10">
                        <TextBox x:Name="IgnoreInput" Width="200" Margin="0,0,8,0"/>
                        <Button Content="Add" Click="AddIgnore_Click" Padding="10,5"/>
                    </WrapPanel>
                    <ListBox x:Name="IgnoreList" Height="120"/>
                </StackPanel>
            </Border>

            <!-- Retention -->
            <Border Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="Data Retention" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                    <WrapPanel>
                        <TextBlock Text="Keep data for" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox x:Name="RetentionInput" Width="60" Text="30" Margin="0,0,5,0"/>
                        <TextBlock Text="days" VerticalAlignment="Center" Margin="0,0,15,0"/>
                        <Button Content="Apply" Click="ApplyRetention_Click" Padding="10,5"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- Data Path -->
            <Border Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="Data File" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                    <TextBlock x:Name="DataPathText" Foreground="#666" FontSize="12"/>
                </StackPanel>
            </Border>

            <!-- Monitoring Status -->
            <Border Background="White" CornerRadius="8" Padding="15">
                <StackPanel>
                    <TextBlock Text="Monitoring" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                    <TextBlock x:Name="StatusText" FontSize="14" Foreground="#27AE60"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>