<Page x:Class="ScreenMonitor.UI.Views.SettingsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="设置" Background="#0C0C1A">
    <ScrollViewer>
        <StackPanel Margin="32,24,32,32">
            <Button Content="← 返回概览" Click="Back_Click"
                    Style="{StaticResource TextBtn}" HorizontalAlignment="Left" Margin="0,0,0,20"/>

            <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="#E8E8F2" Margin="0,0,0,24">
                <Run Text="设置"/></TextBlock>

            <Border Style="{StaticResource Card}" Padding="24,20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="忽略列表" FontSize="15" FontWeight="SemiBold"
                               Foreground="#E8E8F2" Margin="0,0,0,6"/>
                    <TextBlock Text="添加到此列表的进程将不会被记录和显示。点击右侧 ✕ 移出。"
                               Foreground="#9494B8" FontSize="12" Margin="0,0,0,14"/>
                    <WrapPanel Margin="0,0,0,12">
                        <TextBox x:Name="IgnoreInput" Width="220" Style="{StaticResource ModernInput}"
                                 Margin="0,0,10,0"/>
                        <Button Content="添加" Click="AddIgnore_Click" Style="{StaticResource PrimaryBtn}"/>
                    </WrapPanel>
                    <ListBox x:Name="IgnoreList" Height="150"
                             Background="#121226" Foreground="#E8E8F2" BorderBrush="#2A2A4A" BorderThickness="1">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="4,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding}" VerticalAlignment="Center"
                                               FontSize="13" Foreground="#E8E8F2"
                                               TextTrimming="CharacterEllipsis"/>
                                    <Button Grid.Column="1" Content="✕" FontSize="11"
                                            Width="24" Height="24" Padding="0"
                                            Foreground="#FF5C6C" Background="Transparent"
                                            BorderThickness="0" Cursor="Hand"
                                            Click="RemoveIgnore_Click"
                                            ToolTip="移出忽略列表"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Padding="24,20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="数据保留" FontSize="15" FontWeight="SemiBold"
                               Foreground="#E8E8F2" Margin="0,0,0,6"/>
                    <TextBlock Text="清理超出保留天数的历史数据。"
                               Foreground="#9494B8" FontSize="12" Margin="0,0,0,14"/>
                    <WrapPanel>
                        <TextBlock Text="保留最近" VerticalAlignment="Center" Foreground="#C0C0D8" Margin="0,0,8,0" FontSize="13"/>
                        <TextBox x:Name="RetentionInput" Width="70" Text="30"
                                 Style="{StaticResource ModernInput}" Margin="0,0,8,0"/>
                        <TextBlock Text="天的数据" VerticalAlignment="Center" Foreground="#C0C0D8" Margin="0,0,16,0" FontSize="13"/>
                        <Button Content="清理旧数据" Click="ApplyRetention_Click" Style="{StaticResource SecondaryBtn}"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Padding="24,20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="监控状态" FontSize="15" FontWeight="SemiBold"
                               Foreground="#E8E8F2" Margin="0,0,0,6"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Ellipse x:Name="StatusDot" Width="10" Height="10" Fill="#00D9A6" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="StatusText" Grid.Column="1" FontSize="13" Foreground="#00D9A6" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
