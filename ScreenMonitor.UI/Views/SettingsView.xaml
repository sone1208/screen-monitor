<Page x:Class="ScreenMonitor.UI.Views.SettingsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="设置" Background="#1B1B2F">
    <ScrollViewer>
        <StackPanel Margin="28,20,28,30">
            <Button Content="← 返回概览" Click="Back_Click" 
                    Style="{StaticResource TextBtn}" HorizontalAlignment="Left" Margin="0,0,0,16"/>

            <TextBlock FontSize="22" FontWeight="Bold" Foreground="#F0F0FF" Margin="0,0,0,24">
                <Run Text="设置"/></TextBlock>

            <Border Style="{StaticResource Card}" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="忽略列表" FontSize="15" FontWeight="Bold"
                               Foreground="#F0F0FF" Margin="0,0,0,6"/>
                    <TextBlock Text="添加到此列表的进程将不会被记录和显示。"
                               Foreground="#A0A0C0" FontSize="12" Margin="0,0,0,14"/>
                    <WrapPanel Margin="0,0,0,12">
                        <TextBox x:Name="IgnoreInput" Width="220" Style="{StaticResource ModernInput}"
                                 Margin="0,0,10,0"/>
                        <Button Content="添加" Click="AddIgnore_Click" Style="{StaticResource PrimaryBtn}"/>
                    </WrapPanel>
                    <ListBox x:Name="IgnoreList" Height="120"
                             Background="#1A1A30" Foreground="#F0F0FF" BorderBrush="#3A3A5C" BorderThickness="1"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="数据保留" FontSize="15" FontWeight="Bold"
                               Foreground="#F0F0FF" Margin="0,0,0,6"/>
                    <TextBlock Text="清理超出保留天数的历史数据。"
                               Foreground="#A0A0C0" FontSize="12" Margin="0,0,0,14"/>
                    <WrapPanel>
                        <TextBlock Text="保留最近" VerticalAlignment="Center" Foreground="#C0C0D8" Margin="0,0,8,0" FontSize="13"/>
                        <TextBox x:Name="RetentionInput" Width="70" Text="30"
                                 Style="{StaticResource ModernInput}" Margin="0,0,8,0"/>
                        <TextBlock Text="天的数据" VerticalAlignment="Center" Foreground="#C0C0D8" Margin="0,0,16,0" FontSize="13"/>
                        <Button Content="清理旧数据" Click="ApplyRetention_Click" Style="{StaticResource SecondaryBtn}"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="数据文件" FontSize="15" FontWeight="Bold"
                               Foreground="#F0F0FF" Margin="0,0,0,6"/>
                    <TextBlock x:Name="DataPathText" Foreground="#A0A0C0" FontSize="12" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Padding="20">
                <StackPanel>
                    <TextBlock Text="监控状态" FontSize="15" FontWeight="Bold"
                               Foreground="#F0F0FF" Margin="0,0,0,6"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Ellipse x:Name="StatusDot" Width="10" Height="10" Fill="#22C55E" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="StatusText" Grid.Column="1" FontSize="13" Foreground="#22C55E" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
