<Page x:Class="ScreenMonitor.UI.Views.SettingsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="设置" Background="#0B0B1A">
    <ScrollViewer>
        <StackPanel Margin="24,20,24,30">
            <TextBlock FontSize="26" FontWeight="Bold" Margin="0,0,0,24">
                <Run Text="设置" Foreground="#E8E8F8"/>
            </TextBlock>

            <!-- 忽略列表 -->
            <Border Style="{StaticResource Card}" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="忽略列表" FontSize="15" FontWeight="Bold"
                               Foreground="#E8E8F8" Margin="0,0,0,6"/>
                    <TextBlock Text="添加到此列表的进程将不会被记录和显示。"
                               Foreground="#6B6B8D" FontSize="12" Margin="0,0,0,14"/>
                    <WrapPanel Margin="0,0,0,12">
                        <TextBox x:Name="IgnoreInput" Width="220" Style="{StaticResource ModernInput}"
                                 Margin="0,0,10,0"/>
                        <Button Content="添加" Click="AddIgnore_Click" 
                                Style="{StaticResource PrimaryBtn}"/>
                    </WrapPanel>
                    <ListBox x:Name="IgnoreList" Height="120" 
                             Background="#0E0E20" Foreground="#E8E8F8"
                             BorderBrush="#2A2A4A" BorderThickness="1"/>
                </StackPanel>
            </Border>

            <!-- 数据保留 -->
            <Border Style="{StaticResource Card}" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="数据保留" FontSize="15" FontWeight="Bold"
                               Foreground="#E8E8F8" Margin="0,0,0,6"/>
                    <TextBlock Text="清理超出保留天数的历史数据。"
                               Foreground="#6B6B8D" FontSize="12" Margin="0,0,0,14"/>
                    <WrapPanel>
                        <TextBlock Text="保留最近" VerticalAlignment="Center" 
                                   Foreground="#B8B8D0" Margin="0,0,8,0" FontSize="13"/>
                        <TextBox x:Name="RetentionInput" Width="70" Text="30"
                                 Style="{StaticResource ModernInput}"
                                 Margin="0,0,8,0"/>
                        <TextBlock Text="天的数据" VerticalAlignment="Center"
                                   Foreground="#B8B8D0" Margin="0,0,16,0" FontSize="13"/>
                        <Button Content="清理旧数据" Click="ApplyRetention_Click" 
                                Style="{StaticResource SecondaryBtn}"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- 数据文件 -->
            <Border Style="{StaticResource Card}" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="数据文件" FontSize="15" FontWeight="Bold"
                               Foreground="#E8E8F8" Margin="0,0,0,6"/>
                    <TextBlock x:Name="DataPathText" Foreground="#6B6B8D" FontSize="12"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </Border>

            <!-- 监控状态 -->
            <Border Style="{StaticResource Card}" Padding="20">
                <StackPanel>
                    <TextBlock Text="监控状态" FontSize="15" FontWeight="Bold"
                               Foreground="#E8E8F8" Margin="0,0,0,6"/>
                    <Grid Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <!-- 状态圆点 -->
                        <Ellipse x:Name="StatusDot" Width="10" Height="10" 
                                 Fill="#22C55E" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="StatusText" Grid.Column="1" FontSize="13" 
                                   Foreground="#22C55E" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
