<Page x:Class="ScreenMonitor.UI.Views.SettingsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="设置" Background="#131428">
    <ScrollViewer>
        <StackPanel Margin="10">
            <TextBlock Text="设置" FontSize="24" FontWeight="Bold"
                       Foreground="#E8E8F0" Margin="0,0,0,20"/>

            <!-- Ignore List -->
            <Border Background="#1C1E3A" CornerRadius="10" Padding="15"
                    Margin="0,0,0,15" BorderThickness="1" BorderBrush="#2A2C4A">
                <StackPanel>
                    <TextBlock Text="忽略列表" FontSize="16" FontWeight="Bold"
                               Foreground="#E8E8F0" Margin="0,0,0,10"/>
                    <TextBlock Text="添加到此列表的进程将不会被记录和显示。"
                               Foreground="#7A7C94" FontSize="12" Margin="0,0,0,10"/>
                    <WrapPanel Margin="0,0,0,10">
                        <TextBox x:Name="IgnoreInput" Width="200" Height="30"
                                 Background="#131428" Foreground="#E8E8F0"
                                 BorderBrush="#3A3C5A" BorderThickness="1"
                                 VerticalContentAlignment="Center" Padding="6,0"
                                 Margin="0,0,8,0"/>
                        <Button Content="添加" Click="AddIgnore_Click" Padding="12,6" Height="30"
                                Background="#4A8EFF" Foreground="White" BorderThickness="0"/>
                    </WrapPanel>
                    <ListBox x:Name="IgnoreList" Height="120"
                             Background="#131428" Foreground="#E8E8F0"
                             BorderBrush="#3A3C5A" BorderThickness="1"/>
                </StackPanel>
            </Border>

            <!-- Retention -->
            <Border Background="#1C1E3A" CornerRadius="10" Padding="15"
                    Margin="0,0,0,15" BorderThickness="1" BorderBrush="#2A2C4A">
                <StackPanel>
                    <TextBlock Text="数据保留" FontSize="16" FontWeight="Bold"
                               Foreground="#E8E8F0" Margin="0,0,0,10"/>
                    <WrapPanel>
                        <TextBlock Text="保留最近" VerticalAlignment="Center" 
                                   Foreground="#B8B8D0" Margin="0,0,8,0"/>
                        <TextBox x:Name="RetentionInput" Width="60" Height="30" Text="30"
                                 Background="#131428" Foreground="#E8E8F0"
                                 BorderBrush="#3A3C5A" BorderThickness="1"
                                 VerticalContentAlignment="Center" Padding="6,0"
                                 Margin="0,0,5,0"/>
                        <TextBlock Text="天的数据" VerticalAlignment="Center"
                                   Foreground="#B8B8D0" Margin="0,0,15,0"/>
                        <Button Content="应用" Click="ApplyRetention_Click" Padding="12,6" Height="30"
                                Background="#4A8EFF" Foreground="White" BorderThickness="0"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- Data Path -->
            <Border Background="#1C1E3A" CornerRadius="10" Padding="15"
                    Margin="0,0,0,15" BorderThickness="1" BorderBrush="#2A2C4A">
                <StackPanel>
                    <TextBlock Text="数据文件" FontSize="16" FontWeight="Bold"
                               Foreground="#E8E8F0" Margin="0,0,0,10"/>
                    <TextBlock x:Name="DataPathText" Foreground="#7A7C94" FontSize="12"/>
                </StackPanel>
            </Border>

            <!-- Monitoring Status -->
            <Border Background="#1C1E3A" CornerRadius="10" Padding="15"
                    BorderThickness="1" BorderBrush="#2A2C4A">
                <StackPanel>
                    <TextBlock Text="监控状态" FontSize="16" FontWeight="Bold"
                               Foreground="#E8E8F0" Margin="0,0,0,10"/>
                    <TextBlock x:Name="StatusText" FontSize="14" Foreground="#52C41A"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
